type ImageModule = { default: { src: string; width: number; height: number } };
const allCatModules = import.meta.glob<ImageModule>('../assets/neocats/*.png', {eager: true});

const cats = Object.entries(allCatModules).map(([path, mod]) => {
    const filename = path.split('/').pop() || '';
    const raw = filename.replace(/^neocat_?/, '').replace('.png', '');
    const name = raw ? raw.replace(/_/g, ' ') : 'neocat';
    return {src: mod.default.src, name, filename};
});

const catFacts = [
    "The group of words associated with cat (catt, cath, chat, katze) stem from the Latin catus, meaning domestic cat, as opposed to feles, or wild cat.",
    "When a cats rubs up against you, the cat is marking you with it's scent claiming ownership.",
    "When a family cat died in ancient Egypt, family members would mourn by shaving off their eyebrows. They also held elaborate funerals during which they drank wine and beat their breasts. The cat was embalmed with a sculpted wooden mask and the tiny mummy was placed in the family tomb or in a pet cemetery with tiny mummies of mice.",
];

const stretch = Object.fromEntries(
    cats
        .filter(c => c.filename.startsWith('neocat_stretch_'))
        .map(c => [c.filename.replace('neocat_stretch_', '').replace('.png', ''), c.src])
);

const snakeLayout: [number, number, string][] = [
    [1, 1, 'right'],
    [2, 1, 'h'],
    [3, 1, 'h'],
    [4, 1, 'h'],
    [5, 1, 'h'],
    [6, 1, 'h'],
    [7, 1, 'h'],
    [8, 1, 'h'],
    [9, 1, 'h'],
    [10, 1, 'ul'],
    [10, 2, 'v'],
    [10, 3, 'dl'],
    [9, 3, 'h'],
    [8, 3, 'h'],
    [7, 3, 'h'],
    [6, 3, 'h'],
    [5, 3, 'h'],
    [4, 3, 'h'],
    [3, 3, 'h'],
    [2, 3, 'h'],
    [1, 3, 'dr'],
    [1, 2, 'down']
];

const flyingCatDefs = [
	{ file: 'neocat_happy.png',   dur: 2.8, delay: 0     },
	{file: 'neocat_blush.png',   dur: 2.2, delay: -0.5  },
	{ file: 'neocat_heart.png',   dur: 3.1, delay: -1.1  },
	{ file: 'neocat_uwu.png',     dur: 2.5, delay: -1.8  },
	{ file: 'neocat_rainbow.png', dur: 3.4, delay: -0.9 },
	{ file: 'neocat_cool.png',    dur: 2.0, delay: -2.3  },
];
const flyingCats = flyingCatDefs.map(d => ({
	...d,
	cat: cats.find(c => c.filename === d.file),
})).filter(d => d.cat);

const heroOptions = ['neocat_happy.png', 'neocat_heart.png', 'neocat_uwu.png', 'neocat_rainbow.png', 'neocat_blush.png'];
const hero = cats.find(c => c.filename === heroOptions[Math.floor(Math.random() * heroOptions.length)]) ?? cats[0];
const astronautCat = cats.find(c => c.filename === 'neocat_astronaut.png');

// Random side cats
const sideCatCount = 5;
const leftCats = [];
const leftPositions = [];
const leftRotations = [];
const leftOffsets = [];
for (let i = 0; i < sideCatCount; i++) {
    leftCats.push(cats[Math.floor(Math.random() * cats.length)]);
    let pos;
    do {
        pos = Math.random() * 80 + 10; // 10vh to 90vh
    } while (leftPositions.some(p => Math.abs(p - pos) < 15)); // at least 15vh apart
    leftPositions.push(pos);
    leftRotations.push(Math.random() * 360);
    leftOffsets.push(Math.random() * 20 + 5); // 5px to 25px from edge
}

const rightCats = [];
const rightPositions = [];
const rightRotations = [];
const rightOffsets = [];
for (let i = 0; i < sideCatCount; i++) {
    rightCats.push(cats[Math.floor(Math.random() * cats.length)]);
    let pos;
    do {
        pos = Math.random() * 80 + 10; // 10vh to 90vh
    } while (rightPositions.some(p => Math.abs(p - pos) < 15)); // at least 15vh apart
    rightPositions.push(pos);
    rightRotations.push(Math.random() * 360);
    rightOffsets.push(Math.random() * 20 + 5); // 5px to 25px from edge
}

const featured = [
    'neocat_cofe.png', 'neocat_laptop.png', 'neocat_bongo_up.png',
    'neocat_blush.png', 'neocat_cool.png', 'neocat_hug.png',
    'neocat_comfy.png', 'neocat_flag_gay.png',
].map(fn => cats.find(c => c.filename === fn)).filter(Boolean);
